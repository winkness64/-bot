# Runtime env
# 复制本文件为 .env 后再填写。不要提交真实密钥。

# OneBot / NoneBot 基础配置
DRIVER=~fastapi+~httpx+~websockets
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
ONEBOT_ACCESS_TOKEN=
ONEBOT_SECRET=

# NapCat / OneBot v11 接入占位
# 推荐优先使用反向 WebSocket：NapCat 主动连接 NoneBot。
# 下面的 NAPCAT_* 变量主要用于文档提示 / 检查脚本，不一定被 NoneBot 直接读取。
NAPCAT_CONNECTION_MODE=reverse_ws
NAPCAT_REVERSE_WS_URL=ws://127.0.0.1:8080/onebot/v11/ws

# OneBot 兼容占位（按最终接线模式选择填写）
ONEBOT_WS_URL=ws://127.0.0.1:3001/
ONEBOT_API_ROOT=http://127.0.0.1:3000
ONEBOT_WS_REVERSE_URL=ws://127.0.0.1:8080/onebot/v11/ws

# 模型接口：二选一即可
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# MVP 运行开关
YANGYANG_DRY_RUN=1

# Optional runtime overrides
YANGYANG_OWNER_UID=335059272
YANGYANG_BOT_NAME=秧秧

# Phase C4: 长期记忆检索注入配置（默认关闭、仅私聊 owner 灰度）
# memory_long_term_retrieval_enabled=false
# memory_long_term_retrieval_private_only=true
# memory_long_term_retrieval_top_k=3
# memory_long_term_retrieval_char_budget=500
